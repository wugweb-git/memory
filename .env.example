# Identity Prism OS - Environment Template
# Note: These are now OPTIONAL if the System Vault (lib/internal-vault.js) is populated.

NODE_ENV=development
PORT=3000

# Security (Vault Coverage Available)
AUTH_SECRET=
ADMIN_EMAIL=admin@wugweb.com
ADMIN_PASSWORD=

# Infrastructure (Vault Coverage Available)
MONGODB_URI=
OPENAI_API_KEY=
BLOB_READ_WRITE_TOKEN=

# Tuning
ALLOWED_ORIGINS=*
REQUEST_LIMIT_BYTES=1048576
UPLOAD_DIR=/tmp/memory-uploads
BLOB_DATA_PATH=memory/store.json
