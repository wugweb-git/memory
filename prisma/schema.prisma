// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

// --- LAYER 1: MEMORY (NoSQL Memory Store) ---

model MemoryPacket {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  type              String
  source            String
  source_id         String

  content           Json
  metadata          Json

  event_time        DateTime
  ingestion_time    DateTime @default(now())
  last_updated      DateTime @updatedAt

  ownership         String   @default("self")
  sensitivity       String   @default("normal") // normal | restricted

  priority          String   @default("medium") // low | medium | high | critical
  confidence        Float    @default(1.0)

  status            String   @default("active") // active | partial | failed | archived
  hash              String

  trace             Json     // { origin, ingestion_path, parent_origin_id, retry_count, error_reason }
  
  // -- AG HARDENING (LOCKED) --
  embedding_status  String   @default("pending") // pending | processing | embedded | failed
  processing_status String   @default("pending") // pending | retrying | failed | complete
  semantic_status   String   @default("pending") // pending | processing | completed | partial | failed
  
  processing_lock   Boolean  @default(false)
  locked_at         DateTime?
  
  attempt_count     Int      @default(0)
  max_retries       Int      @default(3)
  next_retry_at     DateTime?
  last_retried_at   DateTime?
  retry_classification String? // llm_failure | parse_error | db_error
  
  fallback_used     Boolean  @default(false)
  
  is_embeddable     Boolean  @default(true)
  schema_version    Int      @default(2) // Incremented
  processing_errors Json?    // Array of error objects [{ time, reason, level }]
  semantic_errors   Json?    // Array of error objects [{ time, reason, level }]
  
  test_run_id       String   @default("PROD")

  @@index([source])
  @@index([type])
  @@index([ingestion_time])
  @@index([status])
  @@index([embedding_status])
  @@index([processing_status])
  @@index([semantic_status])
  @@index([test_run_id])
  @@index([processing_lock])
  @@index([hash])
  @@map("memory_packets")
}

model Source {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  type            String   // system | manual | external
  
  trust_score     Float    @default(0.5)
  priority_level  String   @default("medium") // high | medium | low

  auth_status     String   @default("disconnected")
  last_sync       DateTime?
  failure_count   Int      @default(0)

  @@index([name])
  @@map("sources")
}

model ActivityStream {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  packet_id     String   @db.ObjectId
  activity_type String
  timestamp     DateTime @default(now())
  
  intensity     Float?   @default(0.5)
  source        String?
  metadata      Json
  test_run_id   String   @default("PROD")

  @@index([packet_id])
  @@index([timestamp])
  @@index([test_run_id])
  @@map("activity_stream")
}

model Signal {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  packet_id          String   @db.ObjectId
  type               String
  category           String
  source             String
  
  intensity_absolute Float
  intensity_relative Float
  confidence         Float
  source_trust       Float
  
  timestamp          DateTime
  signal_hash        String   @unique
  metadata           Json
  test_run_id        String   @default("PROD")
  processing_state   String   @default("complete")

  @@index([packet_id])
  @@index([type])
  @@index([timestamp])
  @@index([test_run_id])
  @@index([processing_state])
  @@map("signals")
}

model Pattern {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  type              String
  window_type       String   // 7d | 30d | all
  confidence        Float
  signal_count      Int
  consistency_score Float
  last_detected     DateTime @default(now())
  metadata          Json
  test_run_id       String   @default("PROD")
  processing_state  String   @default("complete")

  @@index([type])
  @@index([window_type])
  @@index([test_run_id])
  @@index([processing_state])
  @@map("patterns")
}

// --- DOCUMENTS & ASSETS ---

model Document {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  packet_id    String   @db.ObjectId
  file_name    String
  file_type    String
  file_url     String
  size_bytes   Int
  is_sensitive Boolean  @default(false)
  metadata     Json?
  test_run_id  String   @default("PROD")

  @@index([packet_id])
  @@index([test_run_id])
  @@map("documents")
}

model IngestionLog {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  packet_id     String?  @db.ObjectId
  decision      String   // ACCEPT | HOLD | REDIRECT | REJECT
  reason        String
  timestamp     DateTime @default(now())
  raw_payload   Json?
  test_run_id   String   @default("PROD")

  @@index([timestamp])
  @@index([test_run_id])
  @@map("ingestion_logs")
}

model RetryQueue {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  packet_id     String   @db.ObjectId
  retry_count   Int      @default(0)
  last_attempt  DateTime?
  status        String   @default("pending") // pending | failed
  next_retry_at DateTime?
  test_run_id   String   @default("PROD")

  @@index([status])
  @@index([next_retry_at])
  @@index([test_run_id])
  @@map("retry_queue")
}

model Embedding {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  packet_id       String   @db.ObjectId
  embedding       Float[]
  text_chunk      String
  metadata        Json
  test_run_id     String   @default("PROD")

  @@index([packet_id])
  @@index([test_run_id])
  @@map("embeddings")
}

// --- SYSTEM ---

model User {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  email         String   @unique
  password_hash String
  role          String   @default("user")
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("users")
}

model SystemLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  level      String   @default("info")
  message    String
  user_id    String?
  metadata   Json?
  created_at DateTime @default(now())

  @@index([created_at])
  @@map("system_logs")
}

// --- LAYER 2.5: SEMANTIC ENRICHMENT ---

model SemanticObject {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  packet_id         String   @db.ObjectId
  
  entities          Json     // Array of { name, type, confidence, entity_id }
  intents           Json     // Array of { intent, confidence }
  topics            Json     // Array of { topic, confidence }
  
  model             String   @default("gpt-4o-mini")
  confidence        Float
  verification_status String   @default("verified") // verified | unverified
  fallback          Boolean  @default(false)
  processing_state  String   @default("complete") // pending | complete (atomicity)
  timestamp         DateTime @default(now())
  test_run_id       String   @default("PROD")

  @@index([packet_id])
  @@index([test_run_id])
  @@index([processing_state])
  @@map("semantic_objects")
}

model Entity {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  normalized_name   String
  type              String   // person | organization | project | concept
  confidence        Float
  verification_status String   @default("unverified") // verified | unverified
  fallback          Boolean  @default(false)
  packet_ids        String[] @db.ObjectId
  occurrences       Int      @default(1)
  last_seen         DateTime @default(now())
  
  processing_state  String   @default("complete") // pending | complete (atomicity)
  source_type       String   @default("llm")     // llm | fallback
  dedup_hash        String   // hash(normalized_name + type + test_run_id)
  
  test_run_id       String   @default("PROD")
  
  aliases           EntityAlias[]
  
  @@unique([dedup_hash, test_run_id])
  @@index([normalized_name, type, test_run_id])
  @@index([type])
  @@index([test_run_id])
  @@index([processing_state])
  @@map("entities")
}

model EntityAlias {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  entity_id         String   @db.ObjectId
  alias             String
  confidence        Float
  test_run_id       String   @default("PROD")
  
  entity            Entity      @relation(fields: [entity_id], references: [id])

  @@index([alias, test_run_id])
  @@index([entity_id])
  @@map("entity_aliases")
}

model Relationship {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  from_entity_id    String   @db.ObjectId
  to_entity_id      String   @db.ObjectId
  type              String
  weight            Float
  packet_id         String   @db.ObjectId
  timestamp         DateTime @default(now())
  
  processing_state  String   @default("complete") // pending | complete (atomicity)
  dedup_hash        String   // hash(from_id + to_id + type + test_run_id)
  
  test_run_id       String   @default("PROD")

  @@unique([dedup_hash, test_run_id])
  @@index([from_entity_id])
  @@index([to_entity_id])
  @@index([packet_id])
  @@index([test_run_id])
  @@index([processing_state])
  @@map("relationships")
}

model PendingEdge {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  from_name       String
  to_name         String
  type            String
  weight          Float
  packet_id       String   @db.ObjectId
  test_run_id     String   @default("PROD")
  timestamp       DateTime @default(now())

  @@index([test_run_id])
  @@map("pending_edges")
}

model Topic {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  strength          Float
  packet_ids        String[] @db.ObjectId
  last_updated      DateTime @default(now())
  
  processing_state  String   @default("complete") // pending | complete (atomicity)
  test_run_id       String   @default("PROD")

  @@unique([name, test_run_id])
  @@index([processing_state])
  @@index([test_run_id])
  @@map("topics")
}

model SystemSettings {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  key               String   @unique // e.g., "global_config"
  value             Json     // { semantic_enabled, rag_enabled, model_override }
  last_updated      DateTime @updatedAt

  @@map("system_settings")
}

// --- LAYER 0: QUARANTINE (Blob Store) ---

model BlobItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  type        String
  source      String
  source_id   String?
  raw_payload Json
  file_ref    String?
  size        Int
  hash        String
  state       String   @default("raw")
  trace_json  Json
  owner_id    String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  expires_at  DateTime?
  test_run_id String   @default("PROD")
  events      BlobEvent[]

  @@index([hash])
  @@index([state])
  @@index([test_run_id])
  @@map("blob_items")
}

model BlobEvent {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  blob_id    String   @db.ObjectId
  event_type String
  actor      String?
  payload    Json?
  created_at DateTime @default(now())
  
  blob       BlobItem @relation(fields: [blob_id], references: [id], onDelete: Cascade)

  @@index([blob_id])
  @@map("blob_events")
}
