{
  "functions": {
    "api/index.js": {
      "maxDuration": 20
    }
  },
  "routes": [
    { "src": "/api/chat", "continue": true },
    { "src": "/api/memory/(.*)", "continue": true },
    { "src": "/api/upload", "continue": true },
    { "src": "/admin", "continue": true },
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/(.*)", "continue": true }
  ]
}
